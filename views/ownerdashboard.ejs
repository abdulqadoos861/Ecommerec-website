<!DOCTYPE html>
<html lang="en">
<head>
<meta charset="UTF-8">
<title>Owner Dashboard</title>
<script src="https://cdn.tailwindcss.com"></script>
</head>

<body class="bg-gray-100 flex">

<!-- Sidebar -->
<div class="w-64 bg-gray-900 text-white min-h-screen p-5">

<h1 class="text-2xl font-bold mb-8">Owner Panel</h1>

<nav class="space-y-4">

<a href="#" class="block hover:bg-gray-700 p-2 rounded">Dashboard</a>
<a href="#add" class="block hover:bg-gray-700 p-2 rounded">Add Product</a>
<a href="#products" class="block hover:bg-gray-700 p-2 rounded">Products</a>
<a href="#" class="block hover:bg-gray-700 p-2 rounded">Orders</a>

</nav>

</div>

<!-- Main Content -->
<div class="flex-1 p-6">

<!-- Header -->
<div class="flex justify-between items-center mb-6">
<h2 class="text-3xl font-bold">Dashboard</h2>
<button class="bg-red-500 text-white px-4 py-2 rounded hover:bg-red-600">
Logout
</button>
</div>

<!-- Stats -->
<div class="grid grid-cols-3 gap-4 mb-6">

<div class="bg-white p-4 rounded shadow">
<h3 class="text-gray-500">Total Products</h3>
<p class="text-2xl font-bold">12</p>
</div>

<div class="bg-white p-4 rounded shadow">
<h3 class="text-gray-500">Total Orders</h3>
<p class="text-2xl font-bold">5</p>
</div>

<div class="bg-white p-4 rounded shadow">
<h3 class="text-gray-500">Revenue</h3>
<p class="text-2xl font-bold">$1200</p>
</div>

</div>

<!-- Add Product Form -->
<div id="add" class="bg-white p-6 rounded shadow mb-6">

<h2 class="text-xl font-bold mb-4">Add Product</h2>

<form action="/product/create" method="POST" class="grid grid-cols-2 gap-4">

<input type="text" name="name" placeholder="Product Name"
class="border p-2 rounded" required>

<input type="number" name="price" placeholder="Price"
class="border p-2 rounded" required>

<input type="text" name="image" placeholder="Image URL"
class="border p-2 rounded">

<input type="number" name="stock" placeholder="Stock"
class="border p-2 rounded">

<textarea name="description" placeholder="Description"
class="border p-2 rounded col-span-2"></textarea>

<button type="submit"
class="col-span-2 bg-blue-500 text-white py-2 rounded hover:bg-blue-600">
Add Product
</button>

</form>

</div>

<!-- Product List -->
<div id="products" class="bg-white p-6 rounded shadow">

<h2 class="text-xl font-bold mb-4">Products</h2>

<table class="w-full text-left">

<thead>
<tr class="border-b">
<th class="p-2">Name</th>
<th class="p-2">Price</th>
<th class="p-2">Stock</th>
<th class="p-2">Action</th>
</tr>
</thead>

<tbody>

<tr class="border-b">
<td class="p-2">Shoes</td>
<td class="p-2">$50</td>
<td class="p-2">10</td>
<td class="p-2">
<button class="bg-red-500 text-white px-2 py-1 rounded">Delete</button>
</td>
</tr>

<tr class="border-b">
<td class="p-2">T-Shirt</td>
<td class="p-2">$20</td>
<td class="p-2">25</td>
<td class="p-2">
<button class="bg-red-500 text-white px-2 py-1 rounded">Delete</button>
</td>
</tr>

</tbody>

</table>

</div>

</div>

</body>
</html>